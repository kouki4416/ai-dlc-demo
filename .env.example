# Copy to `.env` and edit values for local development.
# Do NOT commit `.env`.

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root_dev_pw
MYSQL_DATABASE=ideation_portal
MYSQL_USER=app
MYSQL_PASSWORD=apppass
MYSQL_PORT=3306

# ---- Backend ----
NODE_ENV=development
BACKEND_PORT=3001
DATABASE_URL=mysql://app:apppass@db:3306/ideation_portal
JWT_SECRET=change_me_in_production_at_least_32_chars_long_random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
